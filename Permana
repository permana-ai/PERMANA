            </div>
        </div>
    </div>

    <!-- JAVASCRIPT LOGIC -->
    <script>
        const dictionary = {
            id: {
                btn: "EN",
                heroDesc: "Membantu mengoptimalkan produktivitas dan kreativitas kamu lewat produk digital serta AI prompt toolkit berkualitas tinggi.",
                sectionTitle: "Katalog Produk Pilihan",
                sectionBadge: "Produk Aktif",
                stockBadge: "Sisa 2 Slot",
                productDesc: "Tools cerdas untuk menyusun formula prompt yang presisi, konsisten, dan terstruktur guna menghasilkan karya AI bernilai tinggi.",
                priceLabel: "Harga Promo",
                buyBtn: "Lihat Detail",
                modalTitleDetail: "Detail Produk",
                modalTitlePay: "Scan untuk Bayar",
                modalBillLabel: "Total Tagihan",
                modalPriceLabel: "Total Harga",
                proceedBtn: "Lanjutkan Pembayaran →",
                downloadBtn: "📥 Unduh Kode QRIS",
                waBtn: "💬 Kirim Bukti Bayar (WhatsApp)",
                waText: "Halo Permana, saya sudah melakukan pembayaran QRIS untuk ",
                fullProductDesc: `
                    <div class="text-center font-bold text-cyan-400 text-sm mb-2">🔥 Ubah Foto Biasa Jadi Prompt AI Super Detail & Sinematik Dalam Sekali Klik</div>
                    Prompt Generator adalah alat Andalan untuk mengubah gambar acak atau ide sederhana menjadi prompt AI yang rapi, realistis, dan siap menghasilkan visual berkualitas tinggi. Cocok untuk yang menginginkan hasil AI lebih niat, estetika, dan gak keliatan “AI banget”.<br><br>
                    
                    <b>⚡ Yang Dilakukan Tools Ini:</b><br>
                    AI akan membedah setiap detail visual dari gambar yang kamu upload — mulai dari outfit, pencahayaan, warna, angle kamera, background, mood, sampai detail kecil yang sering kelewat. Semuanya langsung dirangkai menjadi generator AI prompt profesional yang mudah dipahami.<br><br>
                    
                    <b>🧠 Cara Kerjanya:</b><br>
                    Unggah Foto ➔ AI Analisis Detail ➔ Sistem Menyusun Prompt Otomatis ➔ Tinggal Copy & Pakai (Tanpa ribet mikirin struktur prompt manual).<br><br>
                    
                    <b>🎯 Kenapa Banyak Orang Pakai?</b><br>
                    • Hasil gambar AI jadi jauh lebih realistis & akurat<br>
                    • Cepat lebih detail, rapih, dan profesional<br>
                    • Hemat waktu bikin prompt dari nol<br>
                    • Cocok untuk berbagai gaya: sinematik, realistis, fotografi jalanan, anime, fashion, dll<br>
                    • Membantu hasil AI lebih konsisten dan estetis<br><br>
                    
                    <b>🚀 Cocok Untuk:</b><br>
                    • Pembuat Konten & Desainer<br>
                    • Seniman AI & Pengembang<br>
                    • Pekerja lepas & Penjual produk digital<br>
                    • Siapa aja yang pengen bikin visual AI lebih pro<br><br>
                    
                    💡 <i>Bahkan foto biasa dari galeri bisa diubah menjadi prompt level premium yang siap dipakai di berbagai generator AI.</i><br><br>
                    <span class="text-cyan-400 font-semibold">📦 Tinggal Upload Foto — Sistem yang Kerja.</span>
                `,
                instructions: `
                    <p class="font-semibold text-slate-300">📌 Langkah Mudah:</p>
                    <p>1. Klik tombol <b>Unduh Kode QRIS</b> di atas atau simpan gambarnya.</p>
                    <p>2. Buka m-Banking atau E-Wallet pilihanmu lalu Scan dari Galeri.</p>
                    <p>3. Setelah sukses transfer, klik tombol konfirmasi bukti bayar di bawah.</p>
                `
            },
            en: {
                btn: "ID",
                heroDesc: "Helping you optimize your productivity and creativity through high-quality digital products and AI prompt toolkits.",
                sectionTitle: "Featured Product Catalog",
                sectionBadge: "Active Product",
                stockBadge: "2 Slots Left",
                productDesc: "Smart tools to craft precise, consistent, and structured prompt formulas to generate high-value AI masterworks.",
                priceLabel: "Promo Price",
                buyBtn: "View Details",
                modalTitleDetail: "Product Details",
                modalTitlePay: "Scan to Pay",
                modalBillLabel: "Total Bill",
                modalPriceLabel: "Total Price",
                proceedBtn: "Proceed to Payment →",
                downloadBtn: "📥 Download QRIS Code",
                waBtn: "💬 Send Payment Proof (WhatsApp)",
                waText: "Hello Permana, I have completed the QRIS payment for ",
                fullProductDesc: `
                    <div class="text-center font-bold text-cyan-400 text-sm mb-2">🔥 Transform Ordinary Photos Into Ultra-Detailed & Cinematic AI Prompts in One Click</div>
                    Prompt Generator is your go-to tool to transform random images or simple ideas into clean, realistic, and production-ready AI prompts. Perfect for anyone wanting deliberate, aesthetic, and completely organic non-synthetic AI results.<br><br>
                    
                    <b>⚡ What This Tool Does:</b><br>
                    The AI breaks down every visual aspect of your uploaded image—from outfits, lighting, color grading, camera angles, backgrounds, moods, down to the tiniest details. Everything is instantly woven into a professional, easy-to-understand AI prompt formula.<br><br>
                    
                    <b>🧠 How It Works:</b><br>
                    Upload Photo ➔ AI Analyzes Details ➔ Automated System Structure ➔ Just Copy & Paste (No manual prompt layout mapping required).<br><br>
                    
                    <b>🎯 Why People Love It:</b><br>
                    • AI images become significantly more realistic & accurate<br>
                    • Fast, comprehensive, neat, and highly professional prompt delivery<br>
                    • Saves tons of time making prompts from scratch<br>
                    • Fits multiple styles: cinematic, realistic, street photo, anime, fashion, etc.<br>
                    • Promotes consistent, artistic output layouts<br><br>
                    
                    <b>🚀 Best For:</b><br>
                    • Content Creators & Designers<br>
                    • AI Artists & System Developers<br>
                    • Freelancers & Digital Product Merchants<br>
                    • Anyone wanting to scale up their visual AI game instantly<br><br>
                    
                    💡 <i>Even a casual gallery snapshot can be turned into a premium-tier prompt ready for any AI generator engine.</i><br><br>
                    <span class="text-cyan-400 font-semibold">📦 Just Upload Your Image — The System Does the Work.</span>
                `,
                instructions: `
                    <p class="font-semibold text-slate-300">📌 Easy Steps:</p>
                    <p>1. Click the <b>Download QRIS Code</b> button above or save the image.</p>
                    <p>2. Open your preferred Bank or E-Wallet app, then Scan from Gallery.</p>
                    <p>3. After successful transfer, click the confirmation button below.</p>
                `
            }
        };

        let currentLang = 'id';
        let selectedProductName = "Ultimate Prompt Generator"; 
        let currentPrice = "Rp85.000";

        function toggleLanguage() {
            currentLang = (currentLang === 'id') ? 'en' : 'id';
            const langData = dictionary[currentLang];

            document.getElementById('langBtn').textContent = langData.btn;
            document.getElementById('heroDesc').textContent = langData.heroDesc;
            document.getElementById('sectionTitle').textContent = langData.sectionTitle;
            document.getElementById('sectionBadge').textContent = langData.sectionBadge;
            document.getElementById('stockBadge').textContent = langData.stockBadge;
            document.getElementById('productDesc').textContent = langData.productDesc;
            document.getElementById('priceLabel').textContent = langData.priceLabel;
            document.getElementById('buyBtn').textContent = langData.buyBtn;
            
            document.getElementById('modalPriceLabel').textContent = langData.modalPriceLabel;
            document.getElementById('proceedBtn').textContent = langData.proceedBtn;
            document.getElementById('modalBillLabel').textContent = langData.modalBillLabel;
            document.getElementById('downloadBtn').innerHTML = langData.downloadBtn;
            document.getElementById('waBtn').innerHTML = langData.waBtn;
            
            renderModalTexts();
        }

        function renderModalTexts() {
            const langData = dictionary[currentLang];
            document.getElementById('modalInstructions').innerHTML = langData.instructions;
            document.getElementById('fullProductDesc').innerHTML = langData.fullProductDesc;
            
            const isPaymentVisible = !document.getElementById('paymentView').classList.contains('hidden');
            document.getElementById('modalTitle').textContent = isPaymentVisible ? langData.modalTitlePay : langData.modalTitleDetail;

            const labelPrefix = (currentLang === 'id') ? "Produk: " : "Product: ";
            document.getElementById('modalProductName').textContent = labelPrefix + selectedProductName;

            const encodedText = encodeURIComponent(langData.waText + selectedProductName + ".");
            const baseWaUrl = "https://wa.me/6285710751443?text="; 
            document.getElementById('waBtn').href = baseWaUrl + encodedText;
        }

        const modal = document.getElementById('qrisModal');
        const modalContent = modal.querySelector('div');
        const descView = document.getElementById('descriptionView');
        const paymentView = document.getElementById('paymentView');

        function openModal(name, price) {
            selectedProductName = name;
            currentPrice = price;
            
            document.getElementById('modalProductPriceView').textContent = price;
            document.getElementById('modalProductPrice').textContent = price;

            descView.classList.remove('hidden');
            paymentView.classList.add('hidden');

            renderModalTexts(); 
            
            modal.classList.remove('opacity-0', 'pointer-events-none');
            setTimeout(() => { modalContent.classList.remove('translate-y-full'); }, 10);
        }

        function proceedToPayment() {
            descView.classList.add('hidden');
            paymentView.classList.remove('hidden');
            document.getElementById('modalTitle').textContent = dictionary[currentLang].modalTitlePay;
        }

        function closeModal() {
            modalContent.classList.add('translate-y-full');
            setTimeout(() => { modal.classList.add('opacity-0', 'pointer-events-none'); }, 300);
        }

        modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });

        // --- 3D TILT EFFECT ---
        const card = document.getElementById('tiltCard');
        card.addEventListener('touchmove', (e) => processTilt(e.touches[0].clientX, e.touches[0].clientY));
        card.addEventListener('touchend', resetTilt);
        card.addEventListener('mousemove', (e) => processTilt(e.clientX, e.clientY));
        card.addEventListener('mouseleave', resetTilt);

        function processTilt(x, y) {
            const rect = card.getBoundingClientRect();
            const cardX = x - rect.left;
            const cardY = y - rect.top;
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;
            const tiltX = ((centerY - cardY) / centerY) * 12;
            const tiltY = ((cardX - centerX) / centerX) * 12;
            card.style.transform = `rotateX(${tiltX}deg) rotateY(${tiltY}deg) scale(1.01)`;
            card.style.boxShadow = `${-tiltY * 1.5}px ${tiltX * 1.5}px 25px rgba(14, 165, 233, 0.15)`;
        }
        function resetTilt() {
            card.style.transform = 'rotateX(0deg) rotateY(0deg) scale(1)';
            card.style.boxShadow = '0 10px 25px -5px rgba(0, 0, 0, 0.5)';
        }

        document.getElementById('modalInstructions').innerHTML = dictionary['id'].instructions;
    </script>
</body>
</html>
